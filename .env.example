# =============================================================================
# ai-decision-audit-log — Environment Variables
# Copy this file to .env and fill in all required values before running.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=             # Required. Your Anthropic API key. sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514  # Default model for Anthropic calls

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=                # Required if using OpenAI SDK. sk-...
OPENAI_MODEL=gpt-4o            # Default model for OpenAI calls

# -----------------------------------------------------------------------------
# llama.cpp (local models via llama-cpp-python — no server required)
# Install with Metal GPU on Apple Silicon:
#   CMAKE_ARGS="-DLLAMA_METAL=on" pip install llama-cpp-python==0.3.16
# Download GGUF models from: https://huggingface.co/TheBloke
# -----------------------------------------------------------------------------
LLAMA_MODEL_PATH=./models/llama3.gguf  # Path to local .gguf model file
LLAMA_N_CTX=4096                       # Context window size (tokens)
LLAMA_N_GPU_LAYERS=-1                  # Layers to offload to Metal GPU (-1 = all)
LLAMA_N_THREADS=4                      # CPU threads (tune to your core count)

# -----------------------------------------------------------------------------
# MCP (Model Context Protocol — TBD, stub only)
# -----------------------------------------------------------------------------
MCP_SERVER_URL=                # MCP server endpoint (required when MCP is activated)
MCP_AUTH_TOKEN=                # MCP auth token (required when MCP is activated)

# -----------------------------------------------------------------------------
# Audit Store
# -----------------------------------------------------------------------------
AUDIT_STORE_PATH=./data/audit.db   # Path to SQLite audit database file
AUDIT_STORE_FORMAT=sqlite          # sqlite | jsonl (storage backend)

# -----------------------------------------------------------------------------
# Hardware (Raspberry Pi — disabled by default)
# -----------------------------------------------------------------------------
GPIO_MODE=BCM                  # BCM or BOARD pin numbering
HARDWARE_ENABLED=false         # Set true only on Pi hardware

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=local              # local | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
